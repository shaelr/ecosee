{
  "name": "ecosee",
  "version": "0.13.6",
  "description": "A full-screen thermostat card for Home Assistant, over any climate entity.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/razzamatazm/ecosee.git"
  },
  "scripts": {
    "dev": "vite",
    "demo": "vite build --config vite.demo.config.ts",
    "build": "tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:browser": "vitest run --config vitest.browser.config.ts",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "lit": "^3.2.1"
  },
  "devDependencies": {
    "@vitest/browser": "^2.1.8",
    "eslint": "^9.17.0",
    "happy-dom": "^20.10.6",
    "playwright": "^1.61.1",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.2",
    "vite": "^6.0.7",
    "vitest": "^2.1.8"
  }
}
